{
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ],
  "env": {
    "VITE_GOOGLE_DRIVE_CLIENT_ID": "664799663034-ifo45hdi681fmse7hpfdl23u307m7j39.apps.googleusercontent.com",
    "VITE_FIREBASE_API_KEY": "AIzaSyCOs67pNwR1sM0X_ISs8cEt0EvDJjlV8gU",
    "VITE_FIREBASE_AUTH_DOMAIN": "verbose-vabxic.firebaseapp.com",
    "VITE_FIREBASE_PROJECT_ID": "verbose-vabxic",
    "VITE_FIREBASE_STORAGE_BUCKET": "verbose-vabxic.firebasestorage.app",
    "VITE_FIREBASE_MESSAGING_SENDER_ID": "397245616723",
    "VITE_FIREBASE_APP_ID": "1:397245616723:web:f7af4c59cbc7a98d626ca6",
    "VITE_FIREBASE_DATABASE_URL": "https://verbose-vabxic-default-rtdb.asia-southeast1.firebasedatabase.app"
  }
}
